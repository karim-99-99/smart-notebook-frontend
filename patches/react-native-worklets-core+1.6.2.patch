+class JsiWrapper {
+public:
+  /**
+   * Base Constructor
+   * @param parent Parent wrapper
+   * @param useProxiesForUnwrapping Uses proxies when unwrapping
+   */
+  explicit JsiWrapper(JsiWrapper *parent, bool useProxiesForUnwrapping)
