{
  "name": "SmartNotebook",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "preandroid": "node scripts/adb-reverse-optional.cjs",
    "android": "react-native run-android --port 8082",
    "android:lan": "node scripts/run-android-lan.cjs",
    "ios": "react-native run-ios",
    "prestart": "node scripts/kill-port.cjs 8082",
    "start": "react-native start --port 8082 --host 0.0.0.0",
    "prestart:android": "node scripts/kill-port.cjs 8082",
    "start:android": "react-native start --port 8082 --host 0.0.0.0",
    "start:clear": "npx expo start --clear",
    "adb:reverse": "adb reverse tcp:8082 tcp:8082",
    "kill-metro": "node scripts/kill-port.cjs 8082",
    "start:fresh": "npm run start",
    "start:tunnel": "npx expo start --tunnel",
    "predev": "node scripts/kill-port.cjs 8082",
    "dev": "react-native start --port 8082 --host 0.0.0.0",
    "test": "jest",
    "postinstall": "node scripts/postinstall.js",
    "eas:build:ios": "npx eas-cli build --platform ios",
    "eas:build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "eas:build:ios:production": "npx eas-cli build --platform ios --profile production",
    "eas:build:ios:production:local": "npx eas-cli build --platform ios --profile production --local",
    "eas:build:android": "npx eas-cli build --platform android",
    "eas:submit:ios": "npx eas-cli submit --platform ios",
    "eas:submit:ios:latest": "npx eas-cli submit --platform ios --latest --profile production",
    "eas:submit:android": "npx eas-cli submit --platform android",
    "eas:update": "npx eas-cli update",
    "eas:login": "npx eas-cli login",
    "eas:logout": "npx eas-cli logout",
    "eas:init": "npx eas-cli init",
    "eas:whoami": "npx eas-cli whoami",
    "generate-qr": "node scripts/generate-qr-image.js",
    "sync-images": "node scripts/sync-images.js"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "^1.13.2",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@supabase/supabase-js": "^2.78.0",
    "expo": "~54.0.30",
    "expo-camera": "~17.0.10",
    "expo-updates": "~29.0.16",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-fs": "^2.20.0",
    "react-native-safe-area-context": "5.6.0",
    "react-native-screens": "4.16.0",
    "react-native-share": "^12.2.1",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-url-polyfill": "^2.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@babel/preset-env": "^7.20.0",
    "@babel/runtime": "^7.20.0",
    "@react-native-community/cli": "^20.0.0",
    "@react-native-community/cli-platform-ios": "^20.0.0",
    "@react-native/babel-preset": "0.81.5",
    "@react-native/eslint-config": "0.81.5",
    "@react-native/metro-config": "0.81.5",
    "@react-native/typescript-config": "0.81.5",
    "@types/react": "~19.1.10",
    "babel-jest": "^29.6.3",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "2.8.8",
    "qrcode": "^1.5.3",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=18"
  }
}
