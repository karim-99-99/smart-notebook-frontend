+  bool evaluateAsBoolean(jsi::Runtime& rt, const jsi::Value& value) {
+    if (value.isUndefined() || value.isNull()) {
+      return false;
+    }
+    
+    if (value.isBool()) {
+      return value.getBool();
+    }
+    
+    if (value.isNumber()) {
+      return value.asNumber() != 0;
+    }
+    
+    // Passing objects or array into this function evals to true in JS
+    return true;
+  }
