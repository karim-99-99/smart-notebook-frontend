{
  "expo": {
    "name": "Smart Notebook",
    "slug": "smartnotebook",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kareem666.smartnotebook",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "Smart Notebook needs camera access to scan your notebook pages",
        "NSPhotoLibraryUsageDescription": "Smart Notebook needs access to save scanned images",
        "NSPhotoLibraryAddUsageDescription": "Smart Notebook needs access to save scanned images to your photo library"
      },
      "runtimeVersion": {
        "policy": "appVersion"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kareem666.smartnotebook",
      "runtimeVersion": "1.0.0"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "58e6d06d-73f7-4fb9-9b89-db773cece8cb"
      }
    },
    "owner": "kareem999",
    "updates": {
      "url": "https://u.expo.dev/58e6d06d-73f7-4fb9-9b89-db773cece8cb"
    }
  }
}
