+  void addDecorator(std::shared_ptr<JsiBaseDecorator> decorator);
+
+  /**
+   Invalidates the instance
+   */
+  static void invalidateDefaultInstance() { defaultInstance = nullptr; }
+
+  JSI_HOST_FUNCTION(addDecorator) {
