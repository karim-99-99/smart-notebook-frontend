+  /**
+   * Used for locking calls from multiple runtimes.
+   */
+  std::recursive_mutex _readWriteMutex;
+
+private:
+  /**
+   * Notify listeners that the value has changed
+   */
+  void notifyListeners() {
+    for (auto listener : _listeners) {
+      (*listener.second)();
+    }
+  }
